# Metro Cardz — Backend Environment Variables
# =============================================
# Copy to .env for local development
# On Render.com: set these in the Environment tab (not committed to git)

# -------------------------------------------------------
# Database (Supabase → Project Settings → Database → Connection String → URI)
# Format: postgresql://user:password@host:port/dbname
# -------------------------------------------------------
DATABASE_URL=postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# -------------------------------------------------------
# Redis (Upstash → your database → REST API → Redis URL)
# Format: redis://default:password@host:port
# -------------------------------------------------------
REDIS_URL=redis://default:your-upstash-password@your-region.upstash.io:6379

# -------------------------------------------------------
# JWT / Security
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# -------------------------------------------------------
SECRET_KEY=change-this-to-a-long-random-string-of-at-least-64-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# -------------------------------------------------------
# App Config
# -------------------------------------------------------
ENVIRONMENT=development   # development | production
DEBUG=true

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://metrocardz.in

# -------------------------------------------------------
# SMS Gateway (Msg91) — Optional for MVP
# Sign up at: https://msg91.com
# -------------------------------------------------------
MSG91_API_KEY=
MSG91_SENDER_ID=METRCZ
MSG91_TEMPLATE_ID_OTP=

# -------------------------------------------------------
# WhatsApp BSP (AiSensy) — Optional for MVP
# Sign up at: https://aisensy.com
# -------------------------------------------------------
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME=metrocardz_reminder

# -------------------------------------------------------
# Object Storage (Supabase Storage — free 1GB)
# Get from: Supabase → Settings → API → Project URL + anon key
# -------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
STORAGE_BUCKET=metrocardz-assets

# -------------------------------------------------------
# Sentry (Error Tracking — free tier)
# Get DSN from: sentry.io → New Project → Python → FastAPI
# -------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# -------------------------------------------------------
# Super Admin (first admin user — created on first startup)
# -------------------------------------------------------
SUPER_ADMIN_PHONE=9000000000
SUPER_ADMIN_NAME=Metro Cardz Admin
