# Metro Cardz — Frontend Environment Variables Template
# =============================================
# Copy this file to .env.local for local development.
# For production: set these as GitHub Secrets (see .github/workflows/deploy.yml)
#
# IMPORTANT: All NEXT_PUBLIC_ variables are embedded at BUILD TIME.
#            Never commit .env.local with real API keys.

# -------------------------------------------------------
# API Configuration
# -------------------------------------------------------
# Backend API base URL (no trailing slash)
# Local dev: http://localhost:8000
# Production: https://api.metrocardz.in  (your Render.com URL)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -------------------------------------------------------
# Feature Flags
# -------------------------------------------------------
# Set to 'false' when the real backend is deployed to use real data.
# Set to 'true' (default) for local development with mock data.
NEXT_PUBLIC_USE_MOCK_DATA=true

# -------------------------------------------------------
# App Config
# -------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Metro Cardz
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENV=development

# Public member card base URL (used in QR codes)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# -------------------------------------------------------
# Sentry (Error Tracking — free tier at sentry.io)
# -------------------------------------------------------
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_SENTRY_DSN=

# -------------------------------------------------------
# Analytics (Google Analytics — optional)
# -------------------------------------------------------
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_GA_MEASUREMENT_ID=
